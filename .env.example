# ─────────────────────────────────────────────────────────
#  RDC PMS – Environment Variables
#  Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────

# ── MOCK MODE ──────────────────────────────────────────────
# Set to "true" to run fully offline with in-memory mock data.
# No Google credentials required in mock mode.
MOCK_MODE=true

# ── GOOGLE SERVICE ACCOUNT ─────────────────────────────────
# Paste the full JSON content of your service account key (minified, one line).
# The service account must have Editor access on each role's Google Sheet.
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# ── ROLE → SHEET MAPPING ───────────────────────────────────
# Comma-separated list of role keys. Each role key must have a matching
# SHEET_ID_<ROLE_KEY> env var below.
#
# Example: ROLE_KEYS=PI,GET,DET
ROLE_KEYS=PI,GET,DET

# Sheet IDs (from the Google Sheet URL: /spreadsheets/d/<SHEET_ID>/edit)
SHEET_ID_PI=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
SHEET_ID_GET=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
SHEET_ID_DET=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Human-readable role labels (used in UI dropdowns)
ROLE_LABEL_PI=Plant Incharge
ROLE_LABEL_GET=Graduate Engineer Trainee
ROLE_LABEL_DET=Diploma Engineer Trainee

# ── APP SETTINGS ───────────────────────────────────────────
# The email/username shown as "current user" when not using auth.
# In a real deployment, replace with proper auth (Google OAuth, etc.)
DEFAULT_USER=hr@rdcconcrete.com

# Super-admin users who can unlock finalized rows (comma-separated emails)
SUPER_ADMINS=admin@rdcconcrete.com

# ── SESSION / SECURITY ─────────────────────────────────────
# Random secret for cookie signing (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=changeme_use_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000
