generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Role Templates ─────────────────────────────────────────────────────────
// One record per role. questions is a JSONB array:
//   [{ key, label, fieldType: 'rating'|'narrative'|'number'|'date', order }]
model RoleTemplate {
  id           String   @id @default(cuid())
  roleKey      String   @unique
  roleLabel    String
  filename     String? // original Excel filename
  questions    Json     @default("[]") // [{question_key, question_label, field_type, display_order}]
  profileCols  Json? // [{key, label, field_type}] — employee profile columns
  rmNameCol    String? // header that holds reviewer (RM/BM) name
  rmEmailCol   String? // header that holds reviewer email
  bhNameCol    String? // header that holds approver (BH) name
  bhEmailCol   String? // header that holds approver email
  includeSelf  Boolean  @default(false) // when true, every pair launched against this template gets a self-assessment step before RM
  // ── V2: post-BH commenter stages (HR_SPOC → HR_HEAD → COTO) ──────────────
  // These three are COMMENTERS, not assessors. Routing is template-level
  // (same trio for every employee under this template). A stage is "active"
  // iff its field list is non-empty AND its routing email is set.
  hrSpocName   String?
  hrSpocEmail  String?
  hrHeadName   String?
  hrHeadEmail  String?
  cotoName     String?
  cotoEmail    String?
  // Field definitions each commenter fills. Same shape as `questions`:
  //   [{ key, label, fieldType: 'narrative'|'rating'|'select'|'number'|'date', order, options? }]
  hrSpocFields Json?
  hrHeadFields Json?
  cotoFields   Json?
  isActive     Boolean  @default(true) // soft-delete flag: false = hidden from dropdowns, history preserved
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employees Employee[]
  pairs     AssessmentPair[]
}

// ── Employees ──────────────────────────────────────────────────────────────
// Uploaded via Excel. Extra profile columns stored in profileData JSONB.
model Employee {
  id          String   @id @default(cuid())
  empCode     String
  empName     String
  roleKey     String
  email       String? // EMP_EMAIL from Excel — used for self-assessment invites
  profileData Json     @default("{}")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  role  RoleTemplate     @relation(fields: [roleKey], references: [roleKey])
  pairs AssessmentPair[]

  @@unique([empCode, roleKey])
}

// ── Assessment Pairs ───────────────────────────────────────────────────────
// One pair = one complete RM+BH assessment cycle for an employee.
// Answers stored as JSONB — fully dynamic, no schema change when questions change.
model AssessmentPair {
  id              String     @id @default(cuid())
  pairId          String     @unique
  empCode         String
  empName         String
  roleKey         String
  cycle           String
  rmName          String
  rmEmail         String
  bhName          String
  bhEmail         String
  status          PairStatus @default(PENDING_RM)
  lockStatus      LockStatus @default(UNLOCKED)
  selectedBy      String?
  selectedOn      DateTime?
  rmSubmittedOn   DateTime?
  bhSubmittedOn   DateTime?
  lastUpdatedBy   String?
  lastUpdatedOn   DateTime?
  rmToken         String     @unique @default(cuid())
  bhToken         String     @unique @default(cuid())
  rmAnswers       Json?
  bhAnswers       Json?
  // Self-assessment branch — only populated when requireSelf=true at launch.
  // Snapshot of RoleTemplate.includeSelf at the moment HR clicked Launch, so
  // toggling the template later doesn't retro-affect in-flight pairs.
  requireSelf     Boolean    @default(false)
  selfToken       String?    @unique @default(cuid())
  selfEmail       String? // captured at launch from Employee.email
  selfName        String? // typically empName — kept for future override
  selfAnswers     Json?
  selfSubmittedOn DateTime?
  selfInvitedOn   DateTime?
  isArchived      Boolean    @default(false)
  archivedOn      DateTime?
  archivedBy      String?
  startOn         DateTime? // if null, starts immediately; else cron fires invites on/after this date
  rmInvitedOn     DateTime? // when the RM dashboard email was sent (null until sent)
  bhInvitedOn     DateTime? // when the BH dashboard email was sent
  // ── V2: snapshot of which post-BH commenter stages this pair runs.
  // Captured at launch from the template so toggling the template later
  // doesn't retro-affect in-flight pairs. The actual commenter data lives
  // in the separate HrReview table (one row per active stage).
  requireHrSpoc   Boolean    @default(false)
  requireHrHead   Boolean    @default(false)
  requireCoto     Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  role      RoleTemplate @relation(fields: [roleKey], references: [roleKey])
  employee  Employee     @relation(fields: [empCode, roleKey], references: [empCode, roleKey])
  logs      AuditLog[]
  hrReviews HrReview[]
}

// ── HR Review (V2) ───────────────────────────────────────────────────────────
// The separate "HR Table". One row per (pair, commenter role). Pre-created at
// launch for each ACTIVE stage so the token exists before the invite email
// goes out. These are view-only commenters on the assessment — they never edit
// self/rm/bh answers; they only fill their own `fields`.
model HrReview {
  id          String    @id @default(cuid())
  pairId      String
  role        String // 'HR_SPOC' | 'HR_HEAD' | 'COTO'
  name        String? // snapshot of template routing name at launch
  email       String? // snapshot of template routing email at launch
  token       String    @unique @default(cuid()) // unique public form URL
  fields      Json? // filled values, keyed by field key from the template
  submittedOn DateTime?
  invitedOn   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  pair AssessmentPair @relation(fields: [pairId], references: [pairId])

  @@unique([pairId, role])
  @@index([pairId])
  @@index([email])
}

// ── Reviewer Link ──────────────────────────────────────────────────────────
// One persistent link per (email, role=RM|BH, roleKey, cycle).
// Used to give an RM/BH a single dashboard URL regardless of how many
// assessments they have in the cycle.
model ReviewerLink {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  email     String
  role      String // "RM" or "BH"
  roleKey   String
  cycle     String
  createdAt DateTime @default(now())

  @@unique([email, role, roleKey, cycle])
  @@index([email])
}

// ── Audit Log ──────────────────────────────────────────────────────────────
model AuditLog {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  action      String
  pairId      String?
  empCode     String?
  empName     String?
  roleKey     String?
  cycle       String?
  performedBy String
  details     Json?

  pair AssessmentPair? @relation(fields: [pairId], references: [pairId])
}

// ── HR Users ───────────────────────────────────────────────────────────────
model HrUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      HrRole   @default(HR_ADMIN)
  password  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

enum PairStatus {
  PENDING_SELF
  PENDING_RM
  RM_SUBMITTED
  PENDING_BH
  // ── V2: post-BH commenter stages. The pair sits in <ROLE>_SUBMITTED while
  // it awaits the NEXT commenter. e.g. BH_SUBMITTED = BH done, awaiting HR_SPOC.
  BH_SUBMITTED
  HR_SPOC_SUBMITTED
  HR_HEAD_SUBMITTED
  FINALIZED
}

enum LockStatus {
  UNLOCKED
  LOCKED
}

enum HrRole {
  HR_ADMIN
  HR_SUPER_ADMIN
}
